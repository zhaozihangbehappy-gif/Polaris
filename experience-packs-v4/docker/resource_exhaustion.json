        "ci_env": []
      },
      "false_paths": [],
      "shortest_verification": {
        "command": "bash -c 'echo \"OCI runtime create failed: setting cgroup config: failed to write to memory.limit_in_bytes: device or resource busy\" >&2; exit 1'",
        "trigger_env": {},
        "expected_stderr_match": "memory\\.limit_in_bytes|Cannot allocate memory",
        "expected_fix_outcome": "different_error_or_success"
      },
      "fix_path": {
        "structured_hints": [
          {
            "kind": "set_env",
            "vars": {
              "DOCKER_MEMORY_LIMIT": "4g"
