      "description": "Crate requires newer rustc \u2014 switch to stable toolchain",
      "source": "prebuilt",
      "trigger_signals": {
        "stderr_regex": [
          "requires rustc \\d+\\.\\d+\\.\\d+ or newer.*currently active rustc version is"
        ],
        "file_markers": [],
        "package_managers": [],
        "ci_env": []
      },
      "false_paths": [],
      "shortest_verification": {
        "command": "bash -c 'echo \"error: package axum v0.7.2 cannot be built because it requires rustc 1.74.0 or newer, while the currently active rustc version is 1.70.0\" >&2; exit 1'",
        "trigger_env": {},
        "expected_stderr_match": "requires rustc.*or newer",
        "expected_fix_outcome": "different_error_or_success"
      },
      "fix_path": {
        "structured_hints": [
          {
            "kind": "set_env",
            "vars": {
              "RUSTUP_TOOLCHAIN": "stable"
            }
          }
        ],
        "fix_command": "bash -c 'echo \"RUSTUP_TOOLCHAIN set (simulated)\"; exit 0'",
        "fix_env": {
          "RUSTUP_TOOLCHAIN": "stable"
