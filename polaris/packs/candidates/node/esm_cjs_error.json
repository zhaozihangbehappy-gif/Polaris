            "content": "let message;\n\ntry {\n  message = require(\"./message.mjs\");\n} catch (error) {\n  if (error && error.code === \"ERR_REQUIRE_ESM\") {\n    throw new Error(\"Must use import to load ES Module: ./message.mjs\");\n  }\n  throw error;\n}\n\nif (message.default !== \"loaded from esm\") {\n  throw new Error(\"unexpected message\");\n}\n\nconsole.log(message.default);\n"
