        "files": [
          {
            "path": "package.json",
            "content": "{\n  \"name\": \"jest-config-js-ts-conflict-fixture\",\n  \"version\": \"1.0.0\",\n  \"private\": true,\n  \"scripts\": {\n    \"test\": \"node check-jest-config.js\"\n  }\n}\n"
          },
          {
            "path": "check-jest-config.js",
            "content": "'use strict';\n\ntry {\n  const config = require('./jest.config.js');\n\n  if (!config || config.testEnvironment !== 'node') {\n    throw new Error('jest config did not export testEnvironment: \"node\"');\n  }\n\n  console.log('jest config loaded');\n} catch (error) {\n  const message = error && error.message ? error.message : String(error);\n  console.error(`jest config error: Could not load jest.config.js: ${message}`);\n  process.exitCode = 1;\n}\n"
          },
          {
            "path": "jest.config.js",
            "content": "'use strict';\n\nmodule.exports = require('./jest.config.ts').default;\n"
          },
          {
            "path": "jest.config.ts",
            "content": "enum TestEnvironment {\n  Node = 'node',\n}\n\nexport default {\n  testEnvironment: TestEnvironment.Node,\n};\n"
          }
        ],
        "reference_fix_files": [
          {
            "path": "jest.config.js",
            "content": "'use strict';\n\nmodule.exports = {\n  testEnvironment: 'node',\n};\n"
          }
        ],
        "fix_rationale": "Keep Jest's JavaScript config self-contained so Node does not try to load the conflicting TypeScript config file.",
        "reviewer_record": {
