            "path": "tsconfig.json",
            "content": "{\n  \"compilerOptions\": {\n    \"module\": \"NodeNext\",\n    \"moduleResolution\": \"NodeNext\"\n  }\n}\n"
          }
        ],
        "fix_rationale": "TypeScript requires module to be NodeNext when moduleResolution is NodeNext, so the config options must agree.",
