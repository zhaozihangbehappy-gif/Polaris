        "files": [
          {
            "path": "package.json",
            "content": "{\n  \"name\": \"eslint-dual-config-failure\",\n  \"version\": \"1.0.0\",\n  \"private\": true,\n  \"scripts\": {\n    \"test\": \"node check-config.js\"\n  }\n}\n"
          },
          {
            "path": "check-config.js",
            "content": "const fs = require(\"node:fs\");\nconst path = require(\"node:path\");\n\nconst root = process.cwd();\n\nfunction readIfPresent(file) {\n  const fullPath = path.join(root, file);\n  return fs.existsSync(fullPath) ? fs.readFileSync(fullPath, \"utf8\") : \"\";\n}\n\nfunction hasLegacyConfig() {\n  const source = readIfPresent(\".eslintrc.json\").trim();\n  if (!source) return false;\n  const parsed = JSON.parse(source);\n  return parsed && typeof parsed === \"object\" && Object.keys(parsed).length > 0;\n}\n\nfunction hasFlatConfig() {\n  return /\\b(module\\.exports|export\\s+default)\\b/.test(readIfPresent(\"eslint.config.js\"));\n}\n\nif (hasLegacyConfig() && hasFlatConfig()) {\n  throw new Error(\"eslint: Both legacy eslintrc config and flat eslint.config.js detected\");\n}\n\nconsole.log(\"eslint config ok\");\n"
          },
          {
            "path": ".eslintrc.json",
            "content": "{\n  \"root\": true,\n  \"env\": {\n    \"node\": true\n  },\n  \"rules\": {\n    \"semi\": \"error\"\n  }\n}\n"
          },
          {
            "path": "eslint.config.js",
            "content": "module.exports = [\n  {\n    files: [\"**/*.js\"],\n    rules: {\n      semi: \"error\"\n    }\n  }\n];\n"
          }
        ],
        "reference_fix_files": [
          {
            "path": "eslint.config.js",
            "content": "// Flat config removed; the project uses .eslintrc.json.\n"
          }
        ],
        "fix_rationale": "Deactivate one ESLint configuration format so the project no longer has both legacy and flat configs active.",
        "reviewer_record": {
          "validated_in_sandbox_at": "2026-04-20T11:20:47+00:00",
