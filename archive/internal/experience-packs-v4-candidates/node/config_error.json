            "content": "{\n  \"compilerOptions\": {\n    \"module\": \"ESNext\",\n    \"moduleResolution\": \"NodeNext\"\n  }\n}\n"
          },
          {
            "path": "check-tsconfig.js",
            "content": "const { readFileSync } = require(\"node:fs\");\n\nconst config = JSON.parse(readFileSync(\"tsconfig.json\", \"utf8\"));\nconst options = config.compilerOptions || {};\n\nif (options.moduleResolution === \"NodeNext\" && options.module !== \"NodeNext\") {\n  throw new Error(\n    `tsconfig moduleResolution mismatch: module must be \"NodeNext\" when moduleResolution is \"NodeNext\", got \"${options.module}\"`\n  );\n}\n"
          }
        ],
