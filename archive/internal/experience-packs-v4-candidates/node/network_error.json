          {
            "path": "check-registry.js",
            "content": "const fs = require(\"node:fs\");\nconst path = require(\"node:path\");\n\nconst fixturePath = path.join(__dirname, \"registry-response.json\");\nconst response = JSON.parse(fs.readFileSync(fixturePath, \"utf8\"));\n\nif (response.status !== 200) {\n  console.error(`npm ERR! ${response.status} ${response.statusText} - GET ${response.url}`);\n  process.exit(1);\n}\n\nif (!response.package || response.package.name !== \"polaris-network-fixture\") {\n  throw new Error(\"registry response did not contain the expected package\");\n}\n\nconsole.log(response.package.version);\n"
          },
          {
            "path": "registry-response.json",
            "content": "{\n  \"status\": 503,\n  \"statusText\": \"Service Unavailable\",\n  \"url\": \"https://registry.npmjs.org/polaris-network-fixture\",\n  \"package\": null\n}\n"
          }
        ],
        "reference_fix_files": [
          {
            "path": "registry-response.json",
            "content": "{\n  \"status\": 200,\n  \"statusText\": \"OK\",\n  \"url\": \"https://registry.npmjs.org/polaris-network-fixture\",\n  \"package\": {\n    \"name\": \"polaris-network-fixture\",\n    \"version\": \"1.0.0\"\n  }\n}\n"
          }
        ],
