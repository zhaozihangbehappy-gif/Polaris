            "path": "deny-global-install.js",
            "content": "const { mkdirSync, mkdtempSync, rmSync } = require(\"node:fs\");\nconst { tmpdir } = require(\"node:os\");\nconst path = require(\"node:path\");\nconst { spawnSync } = require(\"node:child_process\");\n\nconst root = mkdtempSync(path.join(tmpdir(), \"npm-global-ok-\"));\nconst prefix = path.join(root, \"prefix\");\nmkdirSync(prefix, { recursive: true });\n\nconst npm = process.platform === \"win32\" ? \"npm.cmd\" : \"npm\";\nconst result = spawnSync(npm, [\"install\", \"--global\", \".\", \"--prefix\", prefix], {\n  cwd: __dirname,\n  stdio: \"inherit\"\n});\n\nrmSync(root, { recursive: true, force: true });\nprocess.exit(result.status ?? 1);\n"
          }
        ],
        "fix_rationale": "Use a writable npm global prefix instead of forcing npm to install into a read-only directory.",
