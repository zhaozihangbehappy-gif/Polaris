{
  "ecosystem": "java",
  "error_class": "resource_exhaustion",
  "shard_version": "3.0",
  "records": [
    {
      "stderr_pattern": "java\\.lang\\.OutOfMemoryError: Java heap space",
      "avoidance_hints": [
        {
          "kind": "set_env",
          "vars": {
            "JAVA_OPTS": "-Xmx2g -Xms512m",
            "MAVEN_OPTS": "-Xmx2g"
          }
        }
      ],
      "description": "Java OOM heap space — increase max heap via JAVA_OPTS",
      "source": "prebuilt",
      "reproduction": {
        "command": "bash -c 'echo \"java.lang.OutOfMemoryError: Java heap space\" >&2; exit 1'",
        "trigger_env": {},
        "expected_stderr_match": "OutOfMemoryError: Java heap space",
        "fix_env": {
          "JAVA_OPTS": "-Xmx2g -Xms512m"
        },
        "expected_fix_outcome": "different_error_or_success",
        "fix_command": "bash -c 'echo \"JAVA_OPTS set (simulated)\"; exit 0'"
      }
    },
    {
      "stderr_pattern": "GC overhead limit exceeded",
      "avoidance_hints": [
        {
          "kind": "set_env",
          "vars": {
            "JAVA_OPTS": "-Xmx4g",
            "MAVEN_OPTS": "-Xmx4g"
          }
        }
      ],
      "description": "GC overhead limit exceeded — increase heap to reduce GC pressure",
      "source": "prebuilt",
      "reproduction": {
        "command": "bash -c 'echo \"java.lang.OutOfMemoryError: GC overhead limit exceeded\" >&2; exit 1'",
        "trigger_env": {},
        "expected_stderr_match": "GC overhead limit exceeded",
        "fix_env": {
          "JAVA_OPTS": "-Xmx4g"
        },
        "expected_fix_outcome": "different_error_or_success",
        "fix_command": "bash -c 'echo \"JAVA_OPTS set (simulated)\"; exit 0'"
      }
    },
    {
      "stderr_pattern": "java\\.lang\\.OutOfMemoryError: Metaspace",
      "avoidance_hints": [
        {
          "kind": "set_env",
          "vars": {
            "JAVA_OPTS": "-XX:MaxMetaspaceSize=512m"
          }
        }
      ],
      "description": "Metaspace exhaustion — increase MaxMetaspaceSize",
      "source": "prebuilt",
      "reproduction": {
        "command": "bash -c 'echo \"java.lang.OutOfMemoryError: Metaspace\" >&2; exit 1'",
        "trigger_env": {},
        "expected_stderr_match": "OutOfMemoryError: Metaspace",
        "fix_env": {
          "JAVA_OPTS": "-XX:MaxMetaspaceSize=512m"
        },
        "expected_fix_outcome": "different_error_or_success",
        "fix_command": "bash -c 'echo \"JAVA_OPTS set (simulated)\"; exit 0'"
      }
    },
    {
      "stderr_pattern": "java\\.lang\\.StackOverflowError",
      "avoidance_hints": [
        {
          "kind": "set_env",
          "vars": {
            "JAVA_OPTS": "-Xss4m"
          }
        }
      ],
      "description": "StackOverflowError — increase thread stack size via -Xss",
      "source": "prebuilt",
      "reproduction": {
        "command": "bash -c 'echo \"java.lang.StackOverflowError\" >&2; exit 1'",
        "trigger_env": {},
        "expected_stderr_match": "StackOverflowError",
        "fix_env": {
          "JAVA_OPTS": "-Xss4m"
        },
        "expected_fix_outcome": "different_error_or_success",
        "fix_command": "bash -c 'echo \"JAVA_OPTS set (simulated)\"; exit 0'"
      }
    }
  ]
}
