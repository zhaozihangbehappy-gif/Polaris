{
  "ecosystem": "java",
  "error_class": "permission_denial",
  "shard_version": "3.0",
  "records": [
    {
      "stderr_pattern": "java\\.security\\.AccessControlException|Permission denied.*\\.m2",
      "avoidance_hints": [
        {
          "kind": "set_env",
          "vars": {
            "MAVEN_OPTS": "-Dmaven.repo.local=/tmp/.m2"
          }
        }
      ],
      "description": "Maven repository permission denied — redirect to writable /tmp",
      "source": "prebuilt",
      "reproduction": {
        "command": "bash -c 'echo \"Permission denied: /home/user/.m2/repository\" >&2; exit 1'",
        "trigger_env": {},
        "expected_stderr_match": "Permission denied",
        "fix_env": {
          "MAVEN_OPTS": "-Dmaven.repo.local=/tmp/.m2"
        },
        "expected_fix_outcome": "different_error_or_success",
        "fix_command": "bash -c 'echo \"MAVEN_OPTS set (simulated)\"; exit 0'"
      }
    },
    {
      "stderr_pattern": "Permission denied.*\\.gradle|Could not create service.*FileHasher",
      "avoidance_hints": [
        {
          "kind": "set_env",
          "vars": {
            "GRADLE_USER_HOME": "/tmp/.gradle"
          }
        }
      ],
      "description": "Gradle cache permission denied — redirect GRADLE_USER_HOME to writable directory",
      "source": "prebuilt",
      "reproduction": {
        "command": "bash -c 'echo \"Permission denied: /home/user/.gradle/caches/8.5/fileHashes/fileHashes.lock\" >&2; exit 1'",
        "trigger_env": {},
        "expected_stderr_match": "Permission denied.*\\.gradle",
        "fix_env": {
          "GRADLE_USER_HOME": "/tmp/.gradle"
        },
        "expected_fix_outcome": "different_error_or_success",
        "fix_command": "bash -c 'echo \"GRADLE_USER_HOME set (simulated)\"; exit 0'"
      }
    }
  ]
}
