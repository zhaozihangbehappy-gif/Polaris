{
  "ecosystem": "ruby",
  "error_class": "encoding_error",
  "shard_version": "3.0",
  "records": [
    {
      "stderr_pattern": "Encoding::InvalidByteSequenceError|invalid byte sequence in (US-ASCII|UTF-8)",
      "avoidance_hints": [
        {
          "kind": "set_locale",
          "locale": "C.UTF-8"
        }
      ],
      "description": "Ruby encoding error — set locale to UTF-8",
      "source": "prebuilt",
      "reproduction": {
        "command": "bash -c 'echo \"InvalidByteSequenceError\" >&2; exit 1'",
        "trigger_env": {
          "LC_ALL": "C"
        },
        "expected_stderr_match": "InvalidByteSequenceError|invalid byte sequence",
        "fix_env": {
          "LC_ALL": "C.UTF-8"
        },
        "expected_fix_outcome": "different_error_or_success",
        "fix_command": "bash -c 'echo \"locale set to C.UTF-8 (simulated)\"; exit 0'"
      }
    },
    {
      "stderr_pattern": "incompatible character encodings|Encoding::CompatibilityError",
      "avoidance_hints": [
        {
          "kind": "set_env",
          "vars": {
            "RUBYOPT": "-EUTF-8",
            "LANG": "en_US.UTF-8"
          }
        }
      ],
      "description": "Ruby encoding compatibility error — force UTF-8 via RUBYOPT",
      "source": "prebuilt",
      "reproduction": {
        "command": "bash -c 'echo \"incompatible character encodings\" >&2; exit 1'",
        "trigger_env": {
          "LC_ALL": "C",
          "RUBYOPT": ""
        },
        "expected_stderr_match": "incompatible character encodings|CompatibilityError",
        "fix_env": {
          "RUBYOPT": "-EUTF-8",
          "LANG": "en_US.UTF-8"
        },
        "expected_fix_outcome": "different_error_or_success",
        "fix_command": "bash -c 'echo \"RUBYOPT set (simulated)\"; exit 0'"
      }
    }
  ]
}
