{
  "ecosystem": "go",
  "error_class": "network_error",
  "shard_version": "3.0",
  "records": [
    {
      "stderr_pattern": "dial tcp.*i/o timeout|proxy\\.golang\\.org.*timeout|context deadline exceeded.*awaiting headers",
      "avoidance_hints": [
        {
          "kind": "set_env",
          "vars": {
            "GOPROXY": "https://goproxy.cn,direct"
          }
        },
        {
          "kind": "retry_with_backoff",
          "max_retries": 3,
          "base_delay_seconds": 5
        }
      ],
      "description": "Go module proxy unreachable or timed out — switch to alternate proxy and retry",
      "source": "prebuilt",
      "reproduction": {
        "command": "bash -c 'echo \"go: Get \\\"https://proxy.golang.org/github.com/example/pkg/@v/list\\\": dial tcp 142.251.46.17:443: i/o timeout\" >&2; exit 1'",
        "trigger_env": {
          "GOPROXY": "https://proxy.golang.org"
        },
        "expected_stderr_match": "i/o timeout|context deadline exceeded",
        "fix_env": {
          "GOPROXY": "https://goproxy.cn,direct"
        },
        "expected_fix_outcome": "different_error_or_success",
        "fix_command": "bash -c 'echo \"GOPROXY set (simulated)\"; exit 0'"
      }
    },
    {
      "stderr_pattern": "Could not resolve host|server misbehaving|lookup .* on .*: no such host",
      "avoidance_hints": [
        {
          "kind": "set_env",
          "vars": {
            "GOPROXY": "off",
            "GONOSUMCHECK": "*"
          }
        },
        {
          "kind": "retry_with_backoff",
          "max_retries": 2,
          "base_delay_seconds": 10
        }
      ],
      "description": "DNS resolution failure for module host — set GOPROXY=off for local-only or retry",
      "source": "prebuilt",
      "reproduction": {
        "command": "bash -c 'echo \"fatal: unable to access: Could not resolve host: github.com\" >&2; exit 1'",
        "trigger_env": {},
        "expected_stderr_match": "Could not resolve host|no such host",
        "fix_env": {
          "GOPROXY": "off",
          "GONOSUMCHECK": "*"
        },
        "expected_fix_outcome": "different_error_or_success",
        "fix_command": "bash -c 'echo \"GOPROXY set (simulated)\"; exit 0'"
      }
    }
  ]
}
