{
  "ecosystem": "go",
  "error_class": "missing_dependency",
  "shard_version": "3.0",
  "records": [
    {
      "stderr_pattern": "cannot find module providing package|go: module .* found .* but does not contain",
      "avoidance_hints": [{"kind": "set_env", "vars": {"GOFLAGS": "-mod=mod"}}],
      "description": "go module not found — enable module-aware mode to auto-download",
      "source": "prebuilt",
      "reproduction": {
        "command": "go build ./nonexistent 2>&1 || true",
        "trigger_env": {},
        "expected_stderr_match": "cannot find",
        "fix_env": {"GOFLAGS": "-mod=mod"},
        "expected_fix_outcome": "different_error_or_success"
      }
    },
    {
      "stderr_pattern": "missing go\\.sum entry for module|go\\.sum: checksum mismatch",
      "avoidance_hints": [{"kind": "set_env", "vars": {"GONOSUMCHECK": "*", "GOFLAGS": "-mod=mod"}}],
      "description": "go.sum incomplete or mismatch — disable sum check and enable mod download",
      "source": "prebuilt",
      "reproduction": {
        "command": "go mod verify 2>&1 || true",
        "trigger_env": {},
        "expected_stderr_match": "missing go.sum|checksum mismatch",
        "fix_env": {"GONOSUMCHECK": "*", "GOFLAGS": "-mod=mod"},
        "expected_fix_outcome": "different_error_or_success"
      }
    },
    {
      "stderr_pattern": "cannot find package|no required module provides package",
      "avoidance_hints": [{"kind": "set_env", "vars": {"GOPATH": ".", "GOFLAGS": "-mod=mod"}}],
      "description": "Package not found — set GOPATH to cwd and enable module mode",
      "source": "prebuilt",
      "reproduction": {
        "command": "go build ./... 2>&1 || true",
        "trigger_env": {},
        "expected_stderr_match": "cannot find package|no required module",
        "fix_env": {"GOPATH": ".", "GOFLAGS": "-mod=mod"},
        "expected_fix_outcome": "different_error_or_success"
      }
    }
  ]
}
