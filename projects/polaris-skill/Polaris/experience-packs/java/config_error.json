{
  "ecosystem": "java",
  "error_class": "config_error",
  "shard_version": "3.0",
  "records": [
    {
      "stderr_pattern": "JAVA_HOME is not defined correctly|JAVA_HOME is not set|no 'java' command could be found",
      "avoidance_hints": [
        {
          "kind": "set_env",
          "vars": {
            "JAVA_HOME": "/usr/lib/jvm/default-java"
          }
        }
      ],
      "description": "JAVA_HOME not set — point to system JDK installation",
      "source": "prebuilt",
      "reproduction": {
        "command": "bash -c 'echo \"Error: JAVA_HOME is not set and no java command could be found in your PATH.\" >&2; exit 1'",
        "trigger_env": {},
        "expected_stderr_match": "JAVA_HOME is not set",
        "fix_env": {
          "JAVA_HOME": "/usr/lib/jvm/default-java"
        },
        "expected_fix_outcome": "different_error_or_success",
        "fix_command": "bash -c 'echo \"JAVA_HOME set (simulated)\"; exit 0'"
      }
    },
    {
      "stderr_pattern": "Non-parseable POM|The build could not read \\d+ project",
      "avoidance_hints": [
        {
          "kind": "append_flags",
          "flags": [
            "-f",
            "pom.xml"
          ]
        }
      ],
      "description": "Invalid pom.xml — fix XML syntax in POM file",
      "source": "prebuilt",
      "reproduction": {
        "command": "bash -c 'echo \"[FATAL] Non-parseable POM /home/user/project/pom.xml\" >&2; exit 1'",
        "trigger_env": {},
        "expected_stderr_match": "Non-parseable POM",
        "fix_env": {},
        "expected_fix_outcome": "different_error_or_success",
        "fix_command": "bash -c 'echo \"retried with -f pom.xml (simulated)\"; exit 0'"
      }
    }
  ]
}
