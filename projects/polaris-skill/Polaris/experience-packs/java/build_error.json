{
  "ecosystem": "java",
  "error_class": "build_error",
  "shard_version": "3.0",
  "records": [
    {
      "stderr_pattern": "error: release version \\d+ not supported",
      "avoidance_hints": [
        {
          "kind": "set_env",
          "vars": {
            "JAVA_HOME": "/usr/lib/jvm/default-java"
          }
        }
      ],
      "description": "Java release version not supported — set JAVA_HOME to matching JDK",
      "source": "prebuilt",
      "reproduction": {
        "command": "bash -c 'echo \"error: release version 99 not supported\" >&2; exit 1'",
        "trigger_env": {},
        "expected_stderr_match": "not supported",
        "fix_env": {
          "JAVA_HOME": "/usr/lib/jvm/default-java"
        },
        "expected_fix_outcome": "different_error_or_success",
        "fix_command": "bash -c 'echo \"JAVA_HOME set (simulated)\"; exit 0'"
      }
    },
    {
      "stderr_pattern": "COMPILATION ERROR|Compilation failure",
      "avoidance_hints": [
        {
          "kind": "set_env",
          "vars": {
            "JAVA_HOME": "/usr/lib/jvm/java-17-openjdk-amd64"
          }
        }
      ],
      "description": "Maven compilation failure — ensure correct JDK version via JAVA_HOME",
      "source": "prebuilt",
      "reproduction": {
        "command": "bash -c 'echo \"[ERROR] COMPILATION ERROR :\" >&2; echo \"[ERROR] Compilation failure\" >&2; exit 1'",
        "trigger_env": {},
        "expected_stderr_match": "COMPILATION ERROR",
        "fix_env": {
          "JAVA_HOME": "/usr/lib/jvm/java-17-openjdk-amd64"
        },
        "expected_fix_outcome": "different_error_or_success",
        "fix_command": "bash -c 'echo \"JAVA_HOME set (simulated)\"; exit 0'"
      }
    },
    {
      "stderr_pattern": "Task :compileJava FAILED|Execution failed for task ':compileJava'",
      "avoidance_hints": [
        {
          "kind": "set_env",
          "vars": {
            "JAVA_HOME": "/usr/lib/jvm/java-17-openjdk-amd64"
          }
        }
      ],
      "description": "Gradle compileJava task failure — check JAVA_HOME and source compatibility",
      "source": "prebuilt",
      "reproduction": {
        "command": "bash -c 'echo \"> Task :compileJava FAILED\" >&2; echo \"Execution failed for task :compileJava\" >&2; exit 1'",
        "trigger_env": {},
        "expected_stderr_match": "compileJava FAILED",
        "fix_env": {
          "JAVA_HOME": "/usr/lib/jvm/java-17-openjdk-amd64"
        },
        "expected_fix_outcome": "different_error_or_success",
        "fix_command": "bash -c 'echo \"JAVA_HOME set (simulated)\"; exit 0'"
      }
    }
  ]
}
