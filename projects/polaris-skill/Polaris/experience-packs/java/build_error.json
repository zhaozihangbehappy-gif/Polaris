{
  "ecosystem": "java",
  "error_class": "build_error",
  "shard_version": "3.0",
  "records": [
    {
      "stderr_pattern": "error: release version \\d+ not supported|UnsupportedClassVersionError",
      "avoidance_hints": [{"kind": "set_env", "vars": {"JAVA_HOME": "/usr/lib/jvm/default-java"}}],
      "description": "Java version mismatch — set JAVA_HOME to system default",
      "source": "prebuilt",
      "reproduction": {
        "command": "javac --release 99 Main.java 2>&1 || true",
        "trigger_env": {},
        "expected_stderr_match": "not supported",
        "fix_env": {"JAVA_HOME": "/usr/lib/jvm/default-java"},
        "expected_fix_outcome": "different_error_or_success"
      }
    }
  ]
}
