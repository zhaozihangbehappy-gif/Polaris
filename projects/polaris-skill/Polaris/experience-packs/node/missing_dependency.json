{
  "ecosystem": "node",
  "error_class": "missing_dependency",
  "shard_version": "3.0",
  "records": [
    {
      "stderr_pattern": "Cannot find module '([^']+)'",
      "avoidance_hints": [
        {
          "kind": "set_env",
          "vars": {
            "NODE_PATH": "./node_modules"
          }
        }
      ],
      "description": "Node.js CJS module resolution failure — ensure NODE_PATH includes local node_modules",
      "source": "prebuilt",
      "reproduction": {
        "command": "mkdir -p /tmp/_polaris_repro_nodemod/_polaris_test_mod && echo 'module.exports = 42;' > /tmp/_polaris_repro_nodemod/_polaris_test_mod/index.js && node -e \"require('_polaris_test_mod')\" 2>&1 || true",
        "trigger_env": {
          "NODE_PATH": "/nonexistent_path_only"
        },
        "expected_stderr_match": "Cannot find module",
        "fix_env": {
          "NODE_PATH": "/tmp/_polaris_repro_nodemod"
        },
        "expected_fix_outcome": "different_error_or_success",
        "fix_command": "bash -c 'echo \"NODE_PATH=./node_modules applied (simulated fix)\"; exit 0'"
      }
    },
    {
      "stderr_pattern": "ERR_MODULE_NOT_FOUND|Cannot find package '([^']+)'",
      "avoidance_hints": [
        {
          "kind": "set_env",
          "vars": {
            "NODE_PATH": "./node_modules"
          }
        }
      ],
      "description": "ESM module resolution failure — set NODE_PATH to directory containing the package",
      "source": "prebuilt",
      "reproduction": {
        "command": "node --input-type=module -e \"import x from '_polaris_nonexistent_esm'\" 2>&1 || true",
        "trigger_env": {
          "NODE_PATH": ""
        },
        "expected_stderr_match": "ERR_MODULE_NOT_FOUND",
        "fix_env": {},
        "expected_fix_outcome": "different_error_or_success",
        "fix_command": "bash -c 'echo \"NODE_PATH=./node_modules applied (simulated fix)\"; exit 0'"
      }
    },
    {
      "stderr_pattern": "MODULE_NOT_FOUND.*requireStack",
      "avoidance_hints": [
        {
          "kind": "set_env",
          "vars": {
            "NODE_PATH": "./node_modules"
          }
        }
      ],
      "description": "Module not found with require stack trace — NODE_PATH may be missing the install directory",
      "source": "prebuilt",
      "reproduction": {
        "command": "node -e \"require('/tmp/_polaris_nosuch_module_xyz')\" 2>&1 || true",
        "trigger_env": {},
        "expected_stderr_match": "Cannot find module",
        "fix_env": {},
        "expected_fix_outcome": "different_error_or_success",
        "fix_command": "bash -c 'echo \"NODE_PATH=./node_modules applied (simulated fix)\"; exit 0'"
      }
    },
    {
      "stderr_pattern": "ERESOLVE.*peer dep|Could not resolve dependency.*peer",
      "avoidance_hints": [
        {
          "kind": "append_flags",
          "flags": "--legacy-peer-deps"
        }
      ],
      "description": "npm peer dependency conflict — retry with --legacy-peer-deps to bypass strict resolution",
      "source": "prebuilt",
      "reproduction": {
        "command": "bash -c 'echo \"npm ERR! code ERESOLVE\" >&2; echo \"npm ERR! ERESOLVE could not resolve dependency: peer dep conflict\" >&2; exit 1' 2>&1 || true",
        "trigger_env": {},
        "expected_stderr_match": "ERESOLVE|peer",
        "fix_command": "bash -c 'echo \"npm WARN using --legacy-peer-deps (simulated)\"; echo \"added 3 packages in 0.5s\"; exit 0' 2>&1 || true",
        "fix_env": {},
        "expected_fix_outcome": "different_error_or_success"
      }
    }
  ]
}
