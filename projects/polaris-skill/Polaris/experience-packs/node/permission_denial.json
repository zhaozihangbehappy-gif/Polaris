{
  "ecosystem": "node",
  "error_class": "permission_denial",
  "shard_version": "3.0",
  "records": [
    {
      "stderr_pattern": "EACCES: permission denied|npm ERR!.*EACCES",
      "avoidance_hints": [
        {
          "kind": "set_env",
          "vars": {
            "npm_config_cache": "/tmp/.npm-cache"
          }
        }
      ],
      "description": "npm cache permission error — redirect npm cache to writable directory",
      "source": "prebuilt",
      "reproduction": {
        "command": "npm cache ls 2>&1 || true",
        "trigger_env": {
          "npm_config_cache": "/root/.npm-readonly"
        },
        "expected_stderr_match": "EACCES|permission denied",
        "fix_env": {
          "npm_config_cache": "/tmp/.npm-cache"
        },
        "expected_fix_outcome": "different_error_or_success",
        "fix_command": "bash -c 'echo \"npm_config_cache=/tmp/.npm-cache applied (simulated fix)\"; exit 0'"
      }
    },
    {
      "stderr_pattern": "EPERM: operation not permitted|npm ERR!.*EPERM",
      "avoidance_hints": [
        {
          "kind": "set_env",
          "vars": {
            "npm_config_cache": "/tmp/.npm-cache",
            "npm_config_prefix": "/tmp/.npm-global"
          }
        }
      ],
      "description": "npm operation not permitted — typically cache corruption or cross-user ownership; redirect cache and prefix",
      "source": "prebuilt",
      "reproduction": {
        "command": "mkdir -p /tmp/_polaris_repro_eperm && chmod 000 /tmp/_polaris_repro_eperm && node -e \"require('fs').writeFileSync('/tmp/_polaris_repro_eperm/test','x')\" 2>&1; chmod 755 /tmp/_polaris_repro_eperm; rm -rf /tmp/_polaris_repro_eperm || true",
        "trigger_env": {},
        "expected_stderr_match": "EACCES|EPERM|permission",
        "fix_env": {
          "npm_config_cache": "/tmp/.npm-cache"
        },
        "expected_fix_outcome": "different_error_or_success",
        "fix_command": "bash -c 'echo \"npm_config_cache=/tmp/.npm-cache applied (simulated fix)\"; exit 0'"
      }
    }
  ]
}
