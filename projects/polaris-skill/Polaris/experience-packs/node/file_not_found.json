{
  "ecosystem": "node",
  "error_class": "file_not_found",
  "shard_version": "3.0",
  "records": [
    {
      "stderr_pattern": "ENOENT: no such file or directory, open '([^']*package\\.json[^']*)'",
      "avoidance_hints": [
        {
          "kind": "rewrite_cwd",
          "target": "."
        }
      ],
      "description": "package.json not found — cwd may be wrong; rewrite to directory containing package.json",
      "source": "prebuilt",
      "reproduction": {
        "command": "rm -rf /tmp/_polaris_repro_nfnf && node -e \"require('fs').readFileSync('/tmp/_polaris_repro_nfnf/package.json')\" 2>&1 || true",
        "trigger_env": {},
        "expected_stderr_match": "ENOENT",
        "fix_env": {},
        "expected_fix_outcome": "different_error_or_success",
        "fix_command": "bash -c 'echo \"cwd corrected (simulated fix)\"; exit 0'"
      }
    },
    {
      "stderr_pattern": "ENOENT: no such file or directory, (stat|open|lstat) '([^']+)'",
      "avoidance_hints": [
        {
          "kind": "create_dir",
          "path": "."
        }
      ],
      "description": "File or directory missing for fs operation — ensure parent directories exist or build output is present",
      "source": "prebuilt",
      "reproduction": {
        "command": "node -e \"require('fs').statSync('/tmp/_polaris_nosuch_dir_abc/file.txt')\" 2>&1 || true",
        "trigger_env": {},
        "expected_stderr_match": "ENOENT",
        "fix_env": {},
        "expected_fix_outcome": "different_error_or_success",
        "fix_command": "bash -c 'echo \"fix applied (simulated)\"; exit 0'"
      }
    }
  ]
}
