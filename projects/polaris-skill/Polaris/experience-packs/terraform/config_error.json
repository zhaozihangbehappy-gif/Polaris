{
  "ecosystem": "terraform",
  "error_class": "config_error",
  "shard_version": "3.0",
  "records": [
    {
      "stderr_pattern": "Error:.*Missing required provider|provider.*not available",
      "avoidance_hints": [{"kind": "set_env", "vars": {"TF_PLUGIN_CACHE_DIR": "/tmp/.terraform.d/plugin-cache"}}],
      "description": "Terraform provider missing — set plugin cache directory",
      "source": "prebuilt",
      "reproduction": {
        "command": "terraform init 2>&1 || true",
        "trigger_env": {},
        "expected_stderr_match": "Missing required provider|not available",
        "fix_env": {"TF_PLUGIN_CACHE_DIR": "/tmp/.terraform.d/plugin-cache"},
        "expected_fix_outcome": "different_error_or_success"
      }
    },
    {
      "stderr_pattern": "Error:.*backend initialization required",
      "avoidance_hints": [{"kind": "set_env", "vars": {"TF_INPUT": "0"}}],
      "description": "Terraform backend init required — disable interactive input",
      "source": "prebuilt",
      "reproduction": {
        "command": "terraform plan 2>&1 || true",
        "trigger_env": {},
        "expected_stderr_match": "backend initialization",
        "fix_env": {"TF_INPUT": "0"},
        "expected_fix_outcome": "different_error_or_success"
      }
    }
  ]
}
