{
  "ecosystem": "terraform",
  "error_class": "auth_error",
  "shard_version": "3.0",
  "records": [
    {
      "stderr_pattern": "No valid credential sources found|NoCredentialProviders|no valid providers in chain",
      "avoidance_hints": [
        {
          "kind": "set_env",
          "vars": {
            "AWS_PROFILE": "default",
            "AWS_SDK_LOAD_CONFIG": "1"
          }
        }
      ],
      "description": "Terraform AWS credential failure — set default profile and load config",
      "source": "prebuilt",
      "reproduction": {
        "command": "bash -c 'echo \"No valid credential\" >&2; exit 1'",
        "trigger_env": {
          "AWS_ACCESS_KEY_ID": "",
          "AWS_SECRET_ACCESS_KEY": ""
        },
        "expected_stderr_match": "No valid credential|NoCredential",
        "fix_env": {
          "AWS_PROFILE": "default",
          "AWS_SDK_LOAD_CONFIG": "1"
        },
        "expected_fix_outcome": "different_error_or_success",
        "fix_command": "bash -c 'echo \"AWS_PROFILE set (simulated)\"; exit 0'"
      }
    },
    {
      "stderr_pattern": "Error: Unauthorized|status code: 401|status code: 403.*request id",
      "avoidance_hints": [
        {
          "kind": "set_env",
          "vars": {
            "TF_LOG": "DEBUG"
          }
        }
      ],
      "description": "Terraform auth 401/403 — enable debug logging to diagnose",
      "source": "prebuilt",
      "reproduction": {
        "command": "bash -c 'echo \"Unauthorized\" >&2; exit 1'",
        "trigger_env": {},
        "expected_stderr_match": "Unauthorized|401|403",
        "fix_env": {
          "TF_LOG": "DEBUG"
        },
        "expected_fix_outcome": "different_error_or_success",
        "fix_command": "bash -c 'echo \"TF_LOG set (simulated)\"; exit 0'"
      }
    },
    {
      "stderr_pattern": "Could not find default credentials|GOOGLE_CREDENTIALS.*not set|google.*authentication",
      "avoidance_hints": [
        {
          "kind": "set_env",
          "vars": {
            "GOOGLE_CREDENTIALS": "/path/to/service-account.json",
            "GOOGLE_PROJECT": "my-project"
          }
        }
      ],
      "description": "GCP credentials not found — set GOOGLE_CREDENTIALS to service account key path",
      "source": "prebuilt",
      "reproduction": {
        "command": "bash -c 'echo \"Could not find default credentials\" >&2; exit 1'",
        "trigger_env": {
          "GOOGLE_CREDENTIALS": ""
        },
        "expected_stderr_match": "Could not find default credentials|GOOGLE_CREDENTIALS",
        "fix_env": {
          "GOOGLE_CREDENTIALS": "/path/to/service-account.json"
        },
        "expected_fix_outcome": "different_error_or_success",
        "fix_command": "bash -c 'echo \"GOOGLE_CREDENTIALS set (simulated)\"; exit 0'"
      }
    },
    {
      "stderr_pattern": "ExpiredToken|security token.*expired|token has expired",
      "avoidance_hints": [
        {
          "kind": "run_shell",
          "command": "aws sts get-session-token --duration-seconds 3600 || true"
        },
        {
          "kind": "set_env",
          "vars": {
            "AWS_PROFILE": "default"
          }
        }
      ],
      "description": "AWS security token expired — refresh STS session or re-authenticate",
      "source": "prebuilt",
      "reproduction": {
        "command": "bash -c 'echo \"ExpiredToken\" >&2; exit 1'",
        "trigger_env": {
          "AWS_SESSION_TOKEN": "expired-token-value"
        },
        "expected_stderr_match": "ExpiredToken|token.*expired",
        "fix_env": {
          "AWS_SESSION_TOKEN": ""
        },
        "expected_fix_outcome": "different_error_or_success",
        "fix_command": "bash -c 'echo \"AWS_PROFILE set (simulated)\"; exit 0'"
      }
    },
    {
      "stderr_pattern": "ARM_SUBSCRIPTION_ID|ARM_CLIENT_ID|ARM_TENANT_ID|Building AzureRM Client",
      "avoidance_hints": [
        {
          "kind": "set_env",
          "vars": {
            "ARM_SUBSCRIPTION_ID": "<subscription-id>",
            "ARM_CLIENT_ID": "<client-id>",
            "ARM_CLIENT_SECRET": "<client-secret>",
            "ARM_TENANT_ID": "<tenant-id>"
          }
        }
      ],
      "description": "Azure RM provider auth failure — set ARM_* environment variables",
      "source": "prebuilt",
      "reproduction": {
        "command": "bash -c 'echo \"ARM_SUBSCRIPTION_ID\" >&2; exit 1'",
        "trigger_env": {
          "ARM_SUBSCRIPTION_ID": "",
          "ARM_CLIENT_ID": ""
        },
        "expected_stderr_match": "ARM_SUBSCRIPTION_ID|AzureRM Client",
        "fix_env": {
          "ARM_SUBSCRIPTION_ID": "placeholder",
          "ARM_TENANT_ID": "placeholder"
        },
        "expected_fix_outcome": "different_error_or_success",
        "fix_command": "bash -c 'echo \"ARM_SUBSCRIPTION_ID set (simulated)\"; exit 0'"
      }
    }
  ]
}
