{
  "ecosystem": "terraform",
  "error_class": "auth_error",
  "shard_version": "3.0",
  "records": [
    {
      "stderr_pattern": "No valid credential sources found|NoCredentialProviders|ExpiredToken",
      "avoidance_hints": [{"kind": "set_env", "vars": {"AWS_PROFILE": "default", "AWS_SDK_LOAD_CONFIG": "1"}}],
      "description": "Terraform AWS credential failure — set default profile and load config",
      "source": "prebuilt",
      "reproduction": {
        "command": "terraform plan 2>&1 || true",
        "trigger_env": {"AWS_ACCESS_KEY_ID": "", "AWS_SECRET_ACCESS_KEY": ""},
        "expected_stderr_match": "No valid credential|NoCredential",
        "fix_env": {"AWS_PROFILE": "default", "AWS_SDK_LOAD_CONFIG": "1"},
        "expected_fix_outcome": "different_error_or_success"
      }
    },
    {
      "stderr_pattern": "Error: Unauthorized|status code: 401|status code: 403",
      "avoidance_hints": [{"kind": "set_env", "vars": {"TF_LOG": "DEBUG"}}],
      "description": "Terraform auth 401/403 — enable debug logging to diagnose",
      "source": "prebuilt",
      "reproduction": {
        "command": "terraform plan 2>&1 || true",
        "trigger_env": {},
        "expected_stderr_match": "Unauthorized|401|403",
        "fix_env": {"TF_LOG": "DEBUG"},
        "expected_fix_outcome": "different_error_or_success"
      }
    }
  ]
}
