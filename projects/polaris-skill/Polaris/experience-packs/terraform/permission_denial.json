{
  "ecosystem": "terraform",
  "error_class": "permission_denial",
  "shard_version": "3.0",
  "records": [
    {
      "stderr_pattern": "Error:.*permission denied.*\\.terraform|Failed to read plugin dir",
      "avoidance_hints": [{"kind": "set_env", "vars": {"TF_DATA_DIR": "/tmp/.terraform"}}],
      "description": "Terraform plugin dir permission denied — redirect to writable /tmp",
      "source": "prebuilt",
      "reproduction": {
        "command": "terraform init 2>&1 || true",
        "trigger_env": {},
        "expected_stderr_match": "permission denied",
        "fix_env": {"TF_DATA_DIR": "/tmp/.terraform"},
        "expected_fix_outcome": "different_error_or_success"
      }
    }
  ]
}
