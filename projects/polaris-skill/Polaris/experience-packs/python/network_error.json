{
  "ecosystem": "python",
  "error_class": "network_error",
  "shard_version": "3.0",
  "records": [
    {
      "stderr_pattern": "ConnectionRefusedError: \\[Errno 111\\]|Failed to establish a new connection.*Connection refused",
      "avoidance_hints": [
        {
          "kind": "retry_with_backoff",
          "max_retries": 3,
          "base_delay_ms": 2000
        }
      ],
      "description": "Connection refused — retry with backoff in case the service is starting up",
      "source": "prebuilt",
      "reproduction": {
        "command": "python3 -c \"import urllib.request; urllib.request.urlopen('http://127.0.0.1:19876/')\" 2>&1 || true",
        "trigger_env": {},
        "expected_stderr_match": "ConnectionRefusedError|Connection refused",
        "fix_env": {},
        "expected_fix_outcome": "different_error_or_success",
        "fix_command": "bash -c 'echo \"retried with backoff (simulated fix)\"; exit 0'"
      }
    },
    {
      "stderr_pattern": "ssl\\.SSLCertVerificationError|CERTIFICATE_VERIFY_FAILED|SSL: CERTIFICATE_VERIFY_FAILED",
      "avoidance_hints": [
        {
          "kind": "set_env",
          "vars": {
            "REQUESTS_CA_BUNDLE": "",
            "CURL_CA_BUNDLE": ""
          }
        }
      ],
      "description": "SSL certificate verification failed — may need to set CA bundle path or use system certs",
      "source": "prebuilt",
      "reproduction": {
        "command": "python3 -c \"import ssl,urllib.request; ctx=ssl.create_default_context(); ctx.load_verify_locations('/tmp/_polaris_nonexistent_ca.pem')\" 2>&1 || true",
        "trigger_env": {},
        "expected_stderr_match": "SSL|certificate|FileNotFoundError",
        "fix_env": {},
        "expected_fix_outcome": "different_error_or_success",
        "fix_command": "bash -c 'echo \"REQUESTS_CA_BUNDLE= applied (simulated fix)\"; exit 0'"
      }
    }
  ]
}
