{
  "ecosystem": "docker",
  "error_class": "timeout",
  "shard_version": "3.0",
  "records": [
    {
      "stderr_pattern": "context deadline exceeded|TLS handshake timeout",
      "avoidance_hints": [
        {
          "kind": "set_timeout",
          "timeout_ms": 300000
        },
        {
          "kind": "retry_with_backoff",
          "backoff_ms": 5000,
          "max_retries": 3
        }
      ],
      "description": "Docker operation timed out (context deadline or TLS handshake) — increase timeout and retry with backoff",
      "source": "prebuilt",
      "reproduction": {
        "command": "bash -c 'echo \"Error response from daemon: Get https://registry-1.docker.io/v2/: context deadline exceeded\" >&2; exit 1'",
        "trigger_env": {},
        "expected_stderr_match": "context deadline exceeded|TLS handshake timeout",
        "fix_env": {
          "DOCKER_CLIENT_TIMEOUT": "300"
        },
        "expected_fix_outcome": "different_error_or_success",
        "fix_command": "bash -c 'echo \"fix applied\"; exit 0'"
      }
    }
  ]
}
