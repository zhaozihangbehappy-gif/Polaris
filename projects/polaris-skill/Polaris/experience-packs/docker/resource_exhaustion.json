{
  "ecosystem": "docker",
  "error_class": "resource_exhaustion",
  "shard_version": "3.0",
  "records": [
    {
      "stderr_pattern": "no space left on device|Error.*No space left",
      "avoidance_hints": [{"kind": "set_env", "vars": {"DOCKER_BUILDKIT": "1"}}],
      "description": "Docker disk space exhausted — enable BuildKit for better caching",
      "source": "prebuilt",
      "reproduction": {
        "command": "docker build . 2>&1 || true",
        "trigger_env": {},
        "expected_stderr_match": "no space left on device",
        "fix_env": {"DOCKER_BUILDKIT": "1"},
        "expected_fix_outcome": "different_error_or_success"
      }
    }
  ]
}
