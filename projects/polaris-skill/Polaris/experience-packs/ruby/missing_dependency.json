{
  "ecosystem": "ruby",
  "error_class": "missing_dependency",
  "shard_version": "3.0",
  "records": [
    {
      "stderr_pattern": "cannot load such file -- ([^ ]+)|LoadError.*require",
      "avoidance_hints": [
        {
          "kind": "set_env",
          "vars": {
            "RUBYLIB": ".:lib"
          }
        }
      ],
      "description": "Ruby LoadError — add cwd and lib to RUBYLIB",
      "source": "prebuilt",
      "reproduction": {
        "command": "bash -c 'echo \"cannot load such file\" >&2; exit 1'",
        "trigger_env": {},
        "expected_stderr_match": "cannot load such file",
        "fix_env": {
          "RUBYLIB": ".:lib"
        },
        "expected_fix_outcome": "different_error_or_success",
        "fix_command": "bash -c 'echo \"RUBYLIB set (simulated)\"; exit 0'"
      }
    },
    {
      "stderr_pattern": "Could not find gem|Bundler::GemNotFound",
      "avoidance_hints": [
        {
          "kind": "set_env",
          "vars": {
            "BUNDLE_PATH": "vendor/bundle"
          }
        }
      ],
      "description": "Bundler gem not found — set BUNDLE_PATH to local vendor",
      "source": "prebuilt",
      "reproduction": {
        "command": "bash -c 'echo \"Could not find gem\" >&2; exit 1'",
        "trigger_env": {},
        "expected_stderr_match": "Could not find gem",
        "fix_env": {
          "BUNDLE_PATH": "vendor/bundle"
        },
        "expected_fix_outcome": "different_error_or_success",
        "fix_command": "bash -c 'echo \"BUNDLE_PATH set (simulated)\"; exit 0'"
      }
    },
    {
      "stderr_pattern": "Gem::MissingSpecError|Could not find '([^']+)'.*in locally installed gems",
      "avoidance_hints": [
        {
          "kind": "set_env",
          "vars": {
            "GEM_HOME": "/tmp/.gems",
            "GEM_PATH": "/tmp/.gems"
          }
        }
      ],
      "description": "Ruby gem missing — redirect GEM_HOME to writable directory",
      "source": "prebuilt",
      "reproduction": {
        "command": "bash -c 'echo \"MissingSpecError\" >&2; exit 1'",
        "trigger_env": {},
        "expected_stderr_match": "MissingSpecError",
        "fix_env": {
          "GEM_HOME": "/tmp/.gems"
        },
        "expected_fix_outcome": "different_error_or_success",
        "fix_command": "bash -c 'echo \"GEM_HOME set (simulated)\"; exit 0'"
      }
    },
    {
      "stderr_pattern": "Run `bundle install` to install missing gems|Could not find.*in cached gems",
      "avoidance_hints": [
        {
          "kind": "run_command",
          "command": "bundle install --path vendor/bundle"
        }
      ],
      "description": "Bundler cache miss — run bundle install with local path",
      "source": "prebuilt",
      "reproduction": {
        "command": "bash -c 'echo \"install missing gems\" >&2; exit 1'",
        "trigger_env": {
          "BUNDLE_PATH": "vendor/bundle"
        },
        "expected_stderr_match": "install missing gems|cached gems",
        "fix_env": {
          "BUNDLE_PATH": "vendor/bundle"
        },
        "expected_fix_outcome": "different_error_or_success",
        "fix_command": "bash -c 'echo \"ran: bundle install --path vendor/bundle (simulated)\"; exit 0'"
      }
    }
  ]
}
