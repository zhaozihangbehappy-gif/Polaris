{
  "ecosystem": "rust",
  "error_class": "build_error",
  "shard_version": "3.0",
  "records": [
    {
      "stderr_pattern": "error: linker `cc` not found|linker .* not found",
      "avoidance_hints": [{"kind": "set_env", "vars": {"CC": "gcc", "CARGO_INCREMENTAL": "0"}}],
      "description": "Rust linker not found — set CC explicitly",
      "source": "prebuilt",
      "reproduction": {
        "command": "cargo build 2>&1 || true",
        "trigger_env": {"CC": "/nonexistent/cc"},
        "expected_stderr_match": "linker.*not found",
        "fix_env": {"CC": "gcc"},
        "expected_fix_outcome": "different_error_or_success"
      }
    },
    {
      "stderr_pattern": "error: could not compile",
      "avoidance_hints": [{"kind": "set_env", "vars": {"CARGO_INCREMENTAL": "0", "RUSTFLAGS": "-C target-cpu=native"}}],
      "description": "Cargo compilation failure — reset incremental builds",
      "source": "prebuilt",
      "reproduction": {
        "command": "cargo build 2>&1 || true",
        "trigger_env": {},
        "expected_stderr_match": "could not compile",
        "fix_env": {"CARGO_INCREMENTAL": "0"},
        "expected_fix_outcome": "different_error_or_success"
      }
    }
  ]
}
