# Trialogue v2 配置文件模板
# 所有路径必须是绝对路径，不依赖 PATH 或 command -v
# 复制为 scripts/trialogue-v2/trialogue-v2.conf 后按本机环境修改

# 二进制绝对路径
CLAUDE_BIN=/home/administrator/.local/bin/claude
CODEX_BIN=/home/administrator/.local/bin/codex

# 可选：将 Codex 调用委托给独立 runner。
# 为空时维持当前本地直接调用；设置后 launcher.sh 会转交给该 runner。
CODEX_RUNNER=
CODEX_RUNNER_CONF=
CODEX_RUNNER_USER=codex-agent
CODEX_RUNNER_HOME=/srv/trialogue/codex/home
CODEX_RUNNER_WORKSPACE=/srv/trialogue/codex/workspace
CODEX_RUNNER_AUDIT_LOG=/srv/trialogue/codex/audit/audit.jsonl
CODEX_MEMORY_SOURCE_DIR=/srv/trialogue/codex/home/.codex-facts
CODEX_MEMORY_LIVE_DIR=/srv/trialogue/codex/workspace/state/codex-memory-live
CODEX_SANDBOX_MODE=workspace-write
# codex exec 非交互模式当前不会弹审批；有效行为等同 never。
CODEX_APPROVAL_MODE=never

# 审计日志
AUDIT_LOG=/home/administrator/.openclaw/trialogue/audit.jsonl

# Claude session store
CLAUDE_SESSIONS=/home/administrator/.claude/sessions
CLAUDE_PROJECTS=/home/administrator/.claude/projects
CLAUDE_HISTORY=/home/administrator/.claude/history.jsonl

# Codex session store
CODEX_SESSIONS=/home/administrator/.codex/sessions

# 工作目录
WORKSPACE=/home/administrator/.openclaw/workspace
